# ============================================================
# Copy this to .env and fill in your values.
# Never commit .env to version control.
# In production, these come from AWS Secrets Manager.
# ============================================================

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ANNOTATED=alap.text.annotated
KAFKA_CONSUMER_GROUP=vasl-dashboard-consumer
# For local dev (no TLS): leave blank or point to a dummy cert
KAFKA_SSL_CA_LOCATION=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vasl
DB_USER=vasl_user
DB_PASSWORD=vasl_local_pass
DB_SSLMODE=disable   # use "require" in staging/production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_SSL=false      # use "true" in staging/production

# Crisis alert threshold (score >= this triggers immediate Redis pub/sub)
CRISIS_SCORE_THRESHOLD=0.90
