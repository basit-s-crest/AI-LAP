// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Member / User ────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  password         String
  role             String    @default("member")
  avatar           String?
  isVerified       Boolean   @default(false)
  lastActiveAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")
  emailVerifications EmailVerification[]
  coachAssignments CoachMember[]
  coachMessages    CoachMessage[]     @relation("CoachMessages")
  groupMemberships GroupMembership[]
  peerGroupPosts   PeerGroupPost[]
  moods            Mood[]
  organizationId   String?
  organization     Organization?     @relation(fields: [organizationId], references: [id])
  sessionNotes     SessionNote[]
  onboardingAssessments OnboardingAssessment[]
  notifyGroupActivity    Boolean @default(true)
  notifySessionReminders Boolean @default(true)
  notifyDailyCheckin     Boolean @default(false)
  notifyWeeklySummary    Boolean @default(true)
}

// ─── Email Verification OTP ───────────────────────────────────────────────────

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  otp       String   // 6-digit code (stored hashed)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Coach ────────────────────────────────────────────────────────────────────

model Coach {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  avatar      String?
  bio         String?
  speciality  String?
  isActive    Boolean  @default(true)
  lastActiveAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members           CoachMember[]
  coachMessages     CoachMessage[]      @relation("CoachMessages")
  organizationId    String?
  organization      Organization?       @relation(fields: [organizationId], references: [id])
  orgAssignments    OrganizationCoach[]
  sessionNotes      SessionNote[]
  notifySessionReminders  Boolean @default(true)
  notifyNewClientAssigned Boolean @default(true)
  notifyMessageAlerts     Boolean @default(true)
}

model Organization {
  id                     String   @id @default(cuid())
  name                   String
  type                   String   @default("University")
  plan                   String   @default("Starter")
  primaryContactName     String
  primaryContactEmail    String   @unique
  primaryContactPassword String
  domain                 String?
  monthlySpend           Float    @default(0)
  status                 String   @default("active")
  lastActiveAt           DateTime?
  notifyWeeklyReport     Boolean  @default(true)
  notifyCrisisAlerts     Boolean  @default(true)
  notifyNewMembers       Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  members                User[]
  coaches                Coach[]
  coachAssignments       OrganizationCoach[]
}

// ─── Organization ↔ Coach (many-to-many) ──────────────────────────────────────

model OrganizationCoach {
  id             String       @id @default(cuid())
  organizationId String
  coachId        String
  assignedAt     DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  coach          Coach        @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([organizationId, coachId])
  @@index([organizationId])
  @@index([coachId])
}

// ─── Coach ↔ Member assignment ────────────────────────────────────────────────

model CoachMember {
  id        String   @id @default(cuid())
  coachId   String
  userId    String
  assignedAt DateTime @default(now())

  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coachId, userId])
  @@index([coachId])
  @@index([userId])
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

// ─── Community Groups ─────────────────────────────────────────────────────────

model CommunityGroup {
  id          String   @id @default(cuid())
  name        String
  emoji       String   @default("👥")
  description String?
  tags        String[]
  mod         String?
  status      String   @default("active")
  memberIds   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  memberships GroupMembership[]
  posts       PeerGroupPost[]
}

// ─── Coach Messages ───────────────────────────────────────────────────────────

model CoachMessage {
  id         String   @id @default(cuid())
  userId     String
  coachId    String
  content    String
  senderRole String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation("CoachMessages", fields: [userId], references: [id], onDelete: Cascade)
  coach      Coach    @relation("CoachMessages", fields: [coachId], references: [id], onDelete: Cascade)

  @@index([userId, coachId, createdAt])
  @@index([coachId, read])
  @@index([userId, read])
}

model GroupMembership {
  id       String    @id @default(cuid())
  memberId String
  groupId  String
  joinedAt DateTime  @default(now())
  isActive Boolean   @default(true)
  member   User      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  group    CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([memberId, groupId])
  @@index([memberId])
  @@index([groupId])
}

model PeerGroupPost {
  id           String         @id @default(cuid())
  groupId      String
  memberId     String
  body         String
  replyCount   Int            @default(0)
  supportCount Int            @default(0)
  isFlagged    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  group        CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member       User           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@index([memberId])
}

// ─── Daily Mood Tracking ──────────────────────────────────────────────────────

model Mood {
  id        String   @id @default(cuid())
  userId    String
  mood      String   // "GREAT", "GOOD", "OKAY", "LOW", "HARD"
  date      DateTime // Store as date only (midnight UTC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@index([userId, createdAt])
}

// ─── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id                String    @id @default(cuid())
  coachId           String
  memberId          String
  scheduledAt       DateTime
  duration          Int       @default(50)
  type              String    @default("Weekly Check-in")
  status            String    @default("upcoming")
  notes             String?
  cancelledBy       String?
  rescheduleRequest DateTime?
  rescheduleBy      String?
  livekitRoomName   String?   @unique
  livekitStartedAt  DateTime?
  livekitEndedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  sessionNote       SessionNote?
}

// ─── Coach Availability ───────────────────────────────────────────────────────

model CoachAvailability {
  id        String   @id @default(cuid())
  coachId   String   @unique
  slots     Json
  duration  Int      @default(50)
  updatedAt DateTime @updatedAt
}

// ─── Session Notes ────────────────────────────────────────────────────────────

enum SessionNoteStatus {
  DRAFT
  FINAL
}

model SessionNote {
  id              String             @id @default(cuid())
  sessionId       String?            @unique
  coachId         String
  memberId        String
  aiSessionNoteId String?
  status          SessionNoteStatus  @default(DRAFT)
  sessionType     String?            @default("Weekly Check-in")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  session         Session?           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  coach           Coach              @relation(fields: [coachId], references: [id], onDelete: Cascade)
  member          User               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  versions        SessionNoteVersion[]

  @@index([coachId])
  @@index([memberId])
  @@index([coachId, updatedAt(sort: Desc)])
}

model SessionNoteVersion {
  id                  String      @id @default(cuid())
  noteId              String
  version             Int
  summary             String      @db.Text
  keyThemes           Json        // JSON array of strings
  memberSentiment     String
  coachObservations   String      @db.Text
  riskFlag            Boolean     @default(false)
  riskNotes           String      @db.Text @default("")
  recommendedFollowUp String      @db.Text
  createdById         String
  createdAt           DateTime    @default(now())

  sessionNote         SessionNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, version])
  @@index([noteId])
}

// ─── Onboarding Assessment ─────────────────────────────────────────────────────

model OnboardingAssessment {
  id         String   @id @default(cuid())
  userId     String   @unique
  age        String?
  identity   String?
  gender     String?
  orient     String?
  phqAnswers Int[]
  phqScore   Int
  gadAnswers Int[]
  gadScore   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Platform Settings (single-row config) ───────────────────────────────────

model PlatformSettings {
  id                     String   @id @default("platform")
  brandTitle             String   @default("SafeCircle")
  brandTagline           String   @default("Mental Wellness Platform")
  logoUrl                String?
  primaryColor           String   @default("#4E8C58")
  supportEmail           String   @default("support@safecircle.com")
  maxMembersPerCoach     Int      @default(20)
  sessionDurationDefault Int      @default(50)
  sessionDurationMax     Int      @default(90)
  sessionDurationMin     Int      @default(25)
  allowSelfRegistration  Boolean  @default(true)
  maintenanceMode        Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ─── Weekly Reports ───────────────────────────────────────────────────────────

model WeeklyReport {
  id             String   @id @default(cuid())
  organizationId String
  weekStartDate  DateTime // Monday 00:00:00
  weekEndDate    DateTime // Sunday 23:59:59
  reportData     Json     // Stores complete report as JSON
  generatedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@unique([organizationId, weekStartDate])
  @@index([organizationId, weekStartDate(sort: Desc)])
}

model AiSessionNote {
  id                  String   @id @default(uuid())
  sessionId           String?
  memberId            String
  transcript          Json
  summary             String
  keyThemes           Json
  memberSentiment     String
  coachObservations   String
  riskFlag            Boolean  @default(false)
  riskNotes           String   @default("")
  recommendedFollowUp String
  createdAt           DateTime @default(now())
}

