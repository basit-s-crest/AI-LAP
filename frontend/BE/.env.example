# =============================================================================
# frontend/BE — TypeScript Express API
# Copy this file to .env and fill in your values
# =============================================================================

# PostgreSQL connection for Prisma (vasl_ts database)
# If your password has special chars: # -> %23, @ -> %40
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/vasl_ts"

# JWT signing secret — use a long random string
JWT_SECRET="change-me-to-a-long-random-secret"

# Express server port
PORT=4000

# Gmail SMTP — used for email verification OTPs
GMAIL_USER="your-email@gmail.com"
GMAIL_PASS="your-gmail-app-password"

# Python FastAPI backend URL — used for sentiment forwarding
PYTHON_BACKEND_URL="http://localhost:8000"

# Organisation ID sent to Python backend
PYTHON_ORG_ID="org_univ_maryland"

# Frontend URL — used for CORS on Socket.io
FRONTEND_URL="http://localhost:3000"
