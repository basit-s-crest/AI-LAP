# =============================================================================
# frontend/FE — Next.js App + BullMQ Worker
# Copy this file to .env.local and fill in your values
# =============================================================================

# Python FastAPI base URL — used by worker.mjs and API routes
NEXT_PUBLIC_API_URL="http://localhost:8000"
FASTAPI_URL="http://localhost:8000"

# Redis — used by BullMQ queue and worker
REDIS_URL="redis://localhost:6379/0"

# TypeScript Express backend URL — used for auth/messages API calls
NEXT_PUBLIC_BE_URL="http://localhost:4000"

# Default organisation ID sent with chat inference jobs
ORG_ID="org_univ_maryland"
