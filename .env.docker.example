# =============================================================================
# SafeCircle Docker Environment Configuration Template
# Copy this file to .env at the root of the project and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (Supabase - Remote)
# -----------------------------------------------------------------------------
# DATABASE_URL: Used by Express BE (Prisma) and Python Backend (SQLAlchemy)
# DIRECT_URL: Used by Express BE for Prisma migrations (bypasses pgBouncer)
# Note: SQLAlchemy requires the postgresql+psycopg schema.
# Replace the placeholders with your actual Supabase connection strings.
DATABASE_URL="postgresql://postgres.xxx:password@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=15&pool_timeout=30"
DIRECT_URL="postgresql://postgres.xxx:password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"
PYTHON_DATABASE_URL="postgresql+psycopg://postgres.xxx:password@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres"

# -----------------------------------------------------------------------------
# 2. EXPRESS BACKEND (frontend/BE) & AUTH
# -----------------------------------------------------------------------------
PORT=4000
JWT_SECRET="generate_a_random_long_secret_here"
SUPERADMIN_INVITE_CODE="SAFECIRCLE-ADMIN"
PYTHON_ORG_ID="org_univ_maryland"

# Gmail SMTP Settings for Mail notifications
GMAIL_USER="your-email@gmail.com"
GMAIL_PASS="your-gmail-app-password"

# LiveKit Configuration (Cloud or Self-Hosted)
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_WS_URL="ws://localhost:7880"

# -----------------------------------------------------------------------------
# 3. NEXT.JS FRONTEND & BULLMQ WORKER (frontend/FE)
# -----------------------------------------------------------------------------
# Note: Client-side variables (NEXT_PUBLIC_) running in the user's browser
# must point to localhost (or public domain). Server-side variables (FASTAPI_URL, REDIS_URL)
# running inside the Docker network use internal container hostnames.
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_BE_URL="http://localhost:4000"
ORG_ID="org_univ_maryland"

# Internal Docker network references
FASTAPI_URL="http://python:8001"
REDIS_URL="redis://redis:6379/0"

# -----------------------------------------------------------------------------
# 4. PYTHON BACKEND (FastAPI - backend/)
# -----------------------------------------------------------------------------
# API keys for models and processing
OPENROUTER_API_KEY="your-openrouter-key"
GEMINI_API_KEY="your-gemini-key"
GROQ_API_KEY="your-groq-key"
GROQ_MODEL="llama-3.1-8b-instant"
DEEPGRAM_API_KEY="your-deepgram-key"
