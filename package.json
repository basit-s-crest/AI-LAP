{
  "name": "vasl",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev --workspace=backend",
    "build:web": "npm run build --workspace=frontend",
    "build:api": "npm run build --workspace=backend",
    "start:web": "npm run start --workspace=frontend",
    "start:api": "npm run start --workspace=backend",
    "lint": "npm run lint --workspace=frontend",
    "worker": "npm run worker --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "from": "^0.1.7"
  }
}
