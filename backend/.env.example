# =============================================================================
# backend — Python FastAPI (VASL ALAP)
# Copy this file to .env and fill in your values
# =============================================================================

# PostgreSQL connection (vasl database)
# Uses psycopg async driver — note the postgresql+psycopg:// prefix
# If your password has special chars: # -> %23, @ -> %40
DATABASE_URL="postgresql+psycopg://postgres:yourpassword@localhost:5432/vasl"

# LLM Inference Configuration (Google Gemini or OpenRouter)
# For Google Gemini (via Google AI Studio):
GEMINI_API_KEY="AIzaSyCbxzoi4sVOiVC5nPuPsBhpdmfrsGjpQaY"
GEMINI_MODEL="gemini-2.5-flash"

# For OpenRouter (fallback):
OPENROUTER_API_KEY="sk-or-v1-YOUR_KEY_HERE"
OPENROUTER_MODEL="google/gemini-2.0-flash-001"

# Redis — used for pub/sub (risk score updates to frontend SSE stream)
REDIS_URL="redis://localhost:6379/0"
