# ============================================================
# Copy this to .env and fill in your values.
# Never commit .env to version control.
# In production, these come from AWS Secrets Manager.
# ============================================================

# ── Ingestion Gateway ──────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=alap.text.raw
# Leave blank for local dev (no TLS). Set path to CA cert in staging/prod.
KAFKA_SSL_CA_LOCATION=

# ── Kafka Consumer ─────────────────────────────────────────────────────────────
KAFKA_TOPIC_ANNOTATED=alap.text.annotated
KAFKA_CONSUMER_GROUP=vasl-dashboard-consumer

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vasl
DB_USER=vasl_user
DB_PASSWORD=vasl_local_pass
DB_SSLMODE=disable   # use "require" in staging/production

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_SSL=false      # use "true" in staging/production

# ── Crisis alert threshold ─────────────────────────────────────────────────────
# score >= this value triggers immediate Redis pub/sub alert (spec AC-S05)
CRISIS_SCORE_THRESHOLD=0.90
