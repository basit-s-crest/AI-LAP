# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_SSL=false      # use "true" in staging/production

# ── Crisis alert threshold ─────────────────────────────────────────────────────
# score >= this value triggers immediate Redis pub/sub alert (spec AC-S05)
CRISIS_SCORE_THRESHOLD=0.90
